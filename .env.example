# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Used to access admin panel and delete-all endpoint.
ADMIN_PASSWORD="***REMOVED***"

# SUPER_ADMIN_PASSWORD: Server-side password for Central Command location API.
SUPER_ADMIN_PASSWORD="REDACTED"

# VITE_SUPER_ADMIN_PASSWORD: Client-side password for Central Command UI gate.
# Must match SUPER_ADMIN_PASSWORD above.
# Vite exposes all env vars prefixed with VITE_ to the browser bundle.
VITE_SUPER_ADMIN_PASSWORD="REDACTED"
