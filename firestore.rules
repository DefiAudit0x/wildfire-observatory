rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /badgeCodes/{code} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /volunteerRegistrations/{registrationId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /trappedSos/{sosId} {
      allow read: if true;
      allow create, update, delete: if true;
    }
  }
}
